# Optional DarkMesh-only GraphQL metadata shim.
#
# Keep this disabled when you want to use a full external GraphQL service or a
# local indexed Arweave node directly. Enable it only when you want a tiny,
# app-specific metadata cache for DarkMesh resolver modules.
#
# After enabling the service, point HB metadata env to it:
#   GRAPHQL_URL=http://127.0.0.1:18777/graphql
#   GRAPHQL_URLS=http://127.0.0.1:18777/graphql,https://arweave.net/graphql
#   CHECKPOINT_GRAPHQL_URL=http://127.0.0.1:18777/graphql
#
# If you later add a full local GraphQL-capable Arweave node, just replace the
# URL/port above and leave this shim disabled.

DARKMESH_GRAPHQL_SHIM_BIND_HOST=127.0.0.1
DARKMESH_GRAPHQL_SHIM_BIND_PORT=18777
DARKMESH_GRAPHQL_SHIM_ALLOWLIST_FILE=/etc/darkmesh/graphql-shim-allowlist.txt
DARKMESH_GRAPHQL_SHIM_CACHE_DIR=/var/cache/darkmesh-graphql-shim

# Metadata source for allowed tx ids.
# This can stay remote-first on small VPS nodes.
DARKMESH_GRAPHQL_SHIM_TX_BASE_URL=https://arweave.net

# Fallback GraphQL for ids outside the allowlist or unsupported queries.
DARKMESH_GRAPHQL_SHIM_UPSTREAM_GRAPHQL_URL=https://arweave.net/graphql

# 1 = behave like a bigger GraphQL service for misses/unsupported queries.
# 0 = ignore everything outside the allowlist.
DARKMESH_GRAPHQL_SHIM_PROXY_MISSES=1
DARKMESH_GRAPHQL_SHIM_PROXY_UNSUPPORTED=1

# Cache freshness for local tx metadata.
DARKMESH_GRAPHQL_SHIM_CACHE_TTL_SEC=86400
DARKMESH_GRAPHQL_SHIM_REQUEST_TIMEOUT_SEC=15
