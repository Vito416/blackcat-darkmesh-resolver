# Signed host-map projection endpoint.
# Current production preference is a signed dm-hostmap-envelope.v2 fetched from
# a remote control-plane artifact or a local file mirror of that artifact.
# During migration this may still point to legacy v1/v2 JSON, but steady state
# should be signed v2 only.
DARKMESH_PROJECTION_URL=

# Strict signer allowlist (comma-separated key ids).
# Example:
# DARKMESH_PROJECTION_SIGNER_ALLOWLIST=publickey:abc...,publickey:def...
# This is NOT a domain whitelist; domains come from signed projection entries.
DARKMESH_PROJECTION_SIGNER_ALLOWLIST=

# Operational policy approved:
# - projection cadence: 60s (systemd timer)
# - stale policy: keep last-known-good up to 900s (15m), then fail-closed.
DARKMESH_HOST_ROUTING_LKG_MAX_AGE_SEC=900

# Profile notes:
# - Test pool: timer 60s + LKG 900s
# - Production pool: timer 600s (10m) + LKG 7200s, with separate
#   daily/weekly signed AR baseline archive for audit/replay.
# - The active host map now lives in nginx http{} context as a map file, not as
#   a server{} snippet full of host if-statements.

# Optional tuning.
DARKMESH_PROJECTION_FETCH_TIMEOUT_SEC=10
DARKMESH_HOST_ROUTING_MAP_PATH=/etc/nginx/conf.d/darkmesh-host-routing-map.conf
DARKMESH_HOST_ROUTING_STATE_DIR=/var/lib/darkmesh/host-routing
DARKMESH_HOST_ROUTING_RELOAD_ON_CHANGE=1
DARKMESH_NGINX_MAP_HASH_BUCKET_SIZE=128
DARKMESH_NGINX_MAP_HASH_MAX_SIZE=4096

# Signed projection migration controls.
# Dual-stack mode today:
# - v1 envelopes still work when DARKMESH_PROJECTION_REQUIRE_SIGNED=0
# - v2 envelopes are verified through the helper below
# - once all producers emit signed v2, switch REQUIRE_SIGNED=1
DARKMESH_PROJECTION_TRUST_MANIFEST=/etc/darkmesh/projection-trust.json
DARKMESH_PROJECTION_REQUIRE_SIGNED=0
DARKMESH_PROJECTION_VERIFY_BIN=/usr/local/sbin/projection-envelope-tool.py

# Optional target-mode parity guard.
# When enabled, the joined node rebuilds the DM1-derived payload locally from
# live DNS + AR inputs and compares it to the candidate signed projection before
# activation.
# This keeps the worker in a helper/distribution role instead of letting it
# become the only thing a node trusts.
# DARKMESH_PROJECTION_REQUIRE_DM1_PARITY=1
# DARKMESH_PROJECTION_DM1_PARITY_BIN=/usr/local/sbin/verify-projection-dm1-parity.sh
# DARKMESH_PROJECTION_DM1_DNS_URL=https://dns.google/resolve
# DARKMESH_PROJECTION_DM1_AR_BASE=https://arweave.net

# Optional autonomous DM1 bootstrap build (bootstrap/emergency mode only).
# Production verify-only nodes should normally NOT sign or autobuild locally.
# Use this only for controlled bootstrap, lab work, or explicit emergency paths.
# DARKMESH_DM1_AUTOBUILD=1
# DARKMESH_DM1_BUILDER_BIN=/usr/local/sbin/build-host-routing-envelope-from-dm1.sh
# DARKMESH_DM1_DOMAINS_FILE=/etc/darkmesh/projection-domains.txt
# DARKMESH_DM1_DOMAINS_CSV=jdwt.fun,vddl.fun,blgateway.fun
# DARKMESH_DM1_INCLUDE_WWW=1
# DARKMESH_DM1_DNS_URL=https://dns.google/resolve
# DARKMESH_DM1_AR_BASE=https://arweave.net
# DARKMESH_DM1_TTL_SEC=3600
# DARKMESH_DM1_SIGNED_BY=bootstrap-local
# DARKMESH_DM1_KEY_ID=bootstrap-local-key
# DARKMESH_DM1_SIGNATURE_ALG=bootstrap-none
# DARKMESH_DM1_SIGNATURE=bootstrap
# DARKMESH_DM1_ENVELOPE_VERSION=v1
# DARKMESH_DM1_SEQUENCE=0
# DARKMESH_DM1_REFRESH_CADENCE_SEC=60
# DARKMESH_DM1_LKG_MAX_AGE_SEC=900
# DARKMESH_DM1_ISSUED_BY_NODE=resolver-control-eu-1
# DARKMESH_DM1_ISSUED_BY_RESOLVER=darkmesh-resolver-v2
# DARKMESH_DM1_SOURCE_DESCRIPTION=DM1 projection for jdwt/vddl/blgateway
# DARKMESH_DM1_PROJECTION_TOOL_BIN=/usr/local/sbin/projection-envelope-tool.py
# DARKMESH_DM1_SIGN_WITH_PRIVATE_KEY=/etc/darkmesh/projection-signing-key.pem
